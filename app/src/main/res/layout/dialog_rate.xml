<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/gradient_background">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="❤️ Спасибо, что пользуетесь приложением!"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Если вам нравится приложение, поддержите нас оценкой в RuStore. Это очень помогает развитию!"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:lineSpacingExtra="6dp"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:weightSum="2">

        <Button
            android:id="@+id/btnRateNow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Оценить"
            android:backgroundTint="?attr/colorAccent"
            android:layout_marginEnd="8dp"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnRateLater"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Напомнить позже"
            android:backgroundTint="#666666"
            android:layout_marginStart="8dp"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</LinearLayout>
