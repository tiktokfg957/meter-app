<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".AddMeterActivity" />
        <activity android:name=".AddReadingActivity" />
        <activity android:name=".ChartActivity" />
        <activity android:name=".SettingsActivity" />
        <activity android:name=".StatisticsActivity" />
        <activity android:name=".GoalsActivity" />
        <activity android:name=".AddGoalActivity" />
        
        <!-- ЭТА СТРОКА ОБЯЗАТЕЛЬНО ДОЛЖНА БЫТЬ -->
        <activity android:name=".SupportChatActivity" />

        <!-- Виджеты -->
        <receiver
            android:name=".widget.MonthlyCostWidgetProvider"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/monthly_cost_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.GraphWidgetProvider"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/graph_widget_info" />
        </receiver>

    </application>

</manifest>
