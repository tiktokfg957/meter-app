<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".MyApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <!-- Отключаем автоматическую инициализацию SDK -->
        <meta-data
            android:name="com.yandex.mobile.ads.AUTOMATIC_SDK_INITIALIZATION"
            android:value="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".AddMeterActivity" />
        <activity android:name=".AddReadingActivity" />
        <activity android:name=".ChartActivity" />
        <activity android:name=".SettingsActivity" />
        <activity android:name=".StatisticsActivity" />
        <activity android:name=".GoalsActivity" />
        <activity android:name=".AddGoalActivity" />
    </application>

</manifest>
